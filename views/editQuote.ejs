<%- include('partials/header') %>

  <h1>Updating Quote</h1>

  <form method="POST" action="/quote/edit">

    <input type="hidden" name="quoteId" value="<%=quoteInfo[0].quoteId%>">

    Quote:
    <textarea name="quote" rows="4" cols="50"><%=quoteInfo[0].quote%></textarea>
    <br>

    Author:
    <select name="authorId">
      <% authors.forEach(function(author){ %>
        <option value="<%=author.authorId%>"
          <% if (author.authorId == quoteInfo[0].authorId) { %> selected <% } %>>
          <%=author.authorName%>
        </option>
      <% }); %>
    </select>
    <br>

    Category:
    <input type="text" name="category" value="<%=quoteInfo[0].category || ''%>">
    <br>

    Likes:
    <input type="number" name="likes" value="<%=quoteInfo[0].likes || 0%>">
    <br>

    <% if (typeof message != "undefined"){ %>
      <h3><%=message%></h3>
    <% } %>

    <button>Update Quote</button>

  </form>

  <br>
  <a href="/quotes">Back to Quote List</a>

</body>
</html>